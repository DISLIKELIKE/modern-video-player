# .gitignore for modern-video-player

# Build directories
build/
cmake-build-*/
out/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# Compiled files
*.o
*.obj
*.so
*.dll
*.dylib
*.lib
*.a
*.exe
*.out
*.app

# External libraries (Windows)
external/
!external/.gitkeep
!external/quill

# Visual Studio
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
*.vcxproj
*.vcxproj.filters
*.sln

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.nfs*

# IDE
.idea/
*.swp
*.swo
.sublime-*

# Logs
*.log

# Dependencies
*.pc

# Package Manager
vcpkg_installed/
